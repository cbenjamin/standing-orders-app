// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model StandingOrder {
  id                Int                  @id @default(autoincrement())
  shopifyCustomerId String
  customerName      String
  customerEmail     String
  name              String
  startDate         String
  endDate           String
  deliveryDay       Int                  // 0=Sun … 6=Sat
  closeDay          Int                  // day draft locks + converts
  closeTime         String               @default("12:00") // HH:MM in America/New_York
  sendReminder      Boolean              @default(true)
  status            String               @default("active")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  items             StandingOrderItem[]
  draftOrders       DraftOrderRecord[]
}

model StandingOrderItem {
  id               Int            @id @default(autoincrement())
  standingOrderId  Int
  standingOrder    StandingOrder  @relation(fields: [standingOrderId], references: [id], onDelete: Cascade)
  shopifyVariantId String
  productTitle     String
  variantTitle     String?
  price            String
  quantity         Int            @default(1)
}

model DraftOrderRecord {
  id                    Int              @id @default(autoincrement())
  standingOrderId       Int
  standingOrder         StandingOrder    @relation(fields: [standingOrderId], references: [id])
  shopifyDraftOrderId   String
  shopifyDraftOrderName String?
  deliveryDate          String
  status                String           @default("open")
  createdAt             DateTime         @default(now())
  completedOrderId      String?
  completedOrderName    String?
  reminderSentAt        DateTime?
  items                 DraftOrderItem[]
}

model DraftOrderItem {
  id                  Int              @id @default(autoincrement())
  draftOrderRecordId  Int
  draftOrderRecord    DraftOrderRecord @relation(fields: [draftOrderRecordId], references: [id], onDelete: Cascade)
  shopifyVariantId    String
  lineKey             String?
  minimumQuantity     Int              @default(0)
  isStandingItem      Boolean          @default(true)
}
