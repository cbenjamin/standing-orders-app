# Shopify App credentials — set automatically by `shopify app dev`
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=read_customers,write_draft_orders,read_products,read_orders

# Your store's .myshopify.com domain — used by cron jobs and portal
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API public token (Admin → Apps → Develop apps → Storefront API access token)
# Required for customer portal login
SHOPIFY_STOREFRONT_TOKEN=

# Session secret for portal cookie (generate: openssl rand -hex 32)
SESSION_SECRET=change-this-to-a-random-secret

# Cron schedule (default: create at 6am, complete at 9pm)
CRON_DRAFT_CREATE=0 6 * * *
CRON_DRAFT_COMPLETE=0 21 * * *
